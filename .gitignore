# Unity generated/cache folders — regenerated on open, don't belong in history
/Library/
/Temp/
/Obj/
/Logs/
/UserSettings/
/MemoryCaptures/
/Recordings/

# Build output — the 32MB+ zip/exe don't belong in git history; ship via GitHub Releases instead
/Builds/

# OS/editor cruft
.DS_Store
*.pidb.meta
*.pdb.meta
*.mdb.meta
sysinfo.txt
*.apk
*.aab
*.unitypackage
*.app

# Generated project files (regenerated by Unity/IDE on open)
/*.csproj
/*.sln
/*.slnx
*.user
*.userprefs
.vs/

# crashlytics
crashlytics-build.properties

# scratch/session-local
/.claude/
